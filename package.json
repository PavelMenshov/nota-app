{
  "name": "nota-platform",
  "version": "0.1.0",
  "description": "Nota - All-in-One Academic Ecosystem",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:api": "pnpm --filter @nota/api dev",
    "dev:web": "pnpm --filter @nota/web dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "start": "turbo run start",
    "db:generate": "pnpm --filter @nota/database generate",
    "db:build": "pnpm --filter @nota/database build",
    "db:push": "pnpm --filter @nota/database push",
    "db:migrate": "pnpm --filter @nota/database migrate",
    "db:migrate:deploy": "pnpm --filter @nota/database migrate:deploy",
    "db:studio": "pnpm --filter @nota/database studio",
    "db:wipe": "node scripts/wipe-db.js",
    "setup": "pnpm install && pnpm db:build && pnpm db:push",
    "postinstall": "pnpm db:build",
    "clean:next": "node scripts/clean-next.js"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "turbo": "^2.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=8"
  },
  "packageManager": "pnpm@8.15.0"
}
