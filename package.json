{
  "name": "eywa-platform",
  "version": "0.1.0",
  "description": "EYWA - All-in-One Academic Ecosystem",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:api": "pnpm --filter @eywa/api dev",
    "dev:web": "pnpm --filter @eywa/web dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "start": "turbo run start",
    "db:generate": "pnpm --filter @eywa/database generate",
    "db:push": "pnpm --filter @eywa/database push",
    "db:migrate": "pnpm --filter @eywa/database migrate",
    "db:studio": "pnpm --filter @eywa/database studio",
    "setup": "pnpm install && pnpm db:generate && pnpm db:push",
    "postinstall": "pnpm db:generate"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "turbo": "^2.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=8"
  },
  "packageManager": "pnpm@8.15.0"
}
