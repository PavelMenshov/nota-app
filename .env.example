# =================================
# Nota Platform Environment Configuration
# =================================
# Copy this file to .env in the root directory and set real values.
# Never commit .env to version control.
# Also copy to packages/database/.env for Prisma CLI

# =================================
# DOCKER-COMPOSE (for local dev)
# =================================
# Used by docker-compose.yml for PostgreSQL and MinIO. Set these before running docker-compose up.
POSTGRES_PASSWORD="YOUR_POSTGRES_PASSWORD"
MINIO_ROOT_USER="YOUR_MINIO_USER"
MINIO_ROOT_PASSWORD="YOUR_MINIO_PASSWORD"

# =================================
# DATABASE
# =================================
# Main database URL — use the same password as POSTGRES_PASSWORD above for local Docker
DATABASE_URL="postgresql://nota:YOUR_POSTGRES_PASSWORD@localhost:5432/nota?schema=public"

# Direct database URL for Prisma migrations and schema management
# For local development, this can be the same as DATABASE_URL
# In production with connection pooling (e.g., PgBouncer), this should be a direct connection
DIRECT_DATABASE_URL="postgresql://nota:YOUR_POSTGRES_PASSWORD@localhost:5432/nota?schema=public"

# =================================
# REDIS (optional, for caching)
# =================================
REDIS_URL="redis://localhost:6379"

# =================================
# JWT AUTHENTICATION
# =================================
# Required in production. Generate a secure random string, e.g.: openssl rand -base64 32
JWT_SECRET="YOUR_JWT_SECRET_CHANGE_IN_PRODUCTION"
JWT_EXPIRES_IN="7d"

# =================================
# FILE STORAGE (S3-compatible)
# =================================
# For local development with MinIO, use the same MINIO_* values as above
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="YOUR_MINIO_USER"
S3_SECRET_KEY="YOUR_MINIO_PASSWORD"
S3_BUCKET="nota-files"
S3_REGION="us-east-1"

# Local disk fallback (used when S3 is not configured, or for reading files uploaded without S3).
# Must be the same path for upload and stream. Default: <cwd>/uploads
# FILE_UPLOADS_DIR=""

# For production with AWS S3:
# S3_ENDPOINT="https://s3.amazonaws.com"
# S3_ACCESS_KEY="your-aws-access-key"
# S3_SECRET_KEY="your-aws-secret-key"
# S3_BUCKET="your-bucket-name"
# S3_REGION="your-aws-region"

# =================================
# AI SERVICES (REQUIRED FOR AI FEATURES)
# =================================
# Choose one provider and set the API key

# Option 1: OpenAI
# Register at: https://platform.openai.com/signup
# Get API key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=""
# OPENAI_MODEL="gpt-4-turbo-preview"

# Option 2: Anthropic Claude
# Register at: https://console.anthropic.com/
# ANTHROPIC_API_KEY=""
# ANTHROPIC_MODEL="claude-3-opus-20240229"

# AI Provider selection (openai or anthropic)
AI_PROVIDER="openai"
AI_DAILY_LIMIT="50"
# Optional: URL for university library/knowledge-base agent (for deeper academic context)
# LIBRARY_AGENT_URL=""

# =================================
# CORS & FRONTEND
# =================================
# Comma-separated origins; API allows 3000 by default for local dev
CORS_ORIGIN="http://localhost:3000"
# Web app uses this to call API (e.g. PDF stream); set to API base URL
NEXT_PUBLIC_API_URL="http://localhost:4000"

# Direct URL for "Download for Windows" (e.g. GitHub release asset). If unset, button links to releases page.
# Example: https://github.com/OWNER/REPO/releases/latest/download/Nota-Setup-0.1.0.exe
# NEXT_PUBLIC_DESKTOP_WIN_URL=""

# =================================
# SERVER
# =================================
PORT=4000
NODE_ENV="development"

# =================================
# INTEGRATIONS (Zoom, Outlook calendar)
# =================================
# Zoom OAuth — Create app at https://marketplace.zoom.us/
# ZOOM_CLIENT_ID=""
# ZOOM_CLIENT_SECRET=""
# Redirect URI in Zoom app must match (e.g. http://localhost:4000/api/integrations/zoom/callback)
# ZOOM_REDIRECT_URI="http://localhost:4000/api/integrations/zoom/callback"

# Microsoft/Outlook OAuth — Azure app at https://portal.azure.com/ (API permissions: Calendars.ReadWrite, User.Read, offline_access)
# MICROSOFT_CLIENT_ID=""
# MICROSOFT_CLIENT_SECRET=""
# Redirect URI in Azure must match (e.g. http://localhost:4000/api/integrations/outlook/callback)
# MICROSOFT_REDIRECT_URI="http://localhost:4000/api/integrations/outlook/callback"

# Optional: public API URL for OAuth redirect URIs if different from default (e.g. https://api.example.com)
# API_PUBLIC_URL="http://localhost:4000"

# =================================
# OPTIONAL: OAUTH PROVIDERS (SSO)
# =================================
# Google OAuth — Register at: https://console.cloud.google.com/
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# GitHub OAuth — Register at: https://github.com/settings/developers
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""

# =================================
# OPTIONAL: EMAIL SERVICE
# =================================
# For sending verification emails, password resets, etc.
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASSWORD=""
# EMAIL_FROM="noreply@nota.app"

# =================================
# OPTIONAL: ANALYTICS
# =================================
# NEXT_PUBLIC_POSTHOG_KEY=""
# NEXT_PUBLIC_POSTHOG_HOST=""
