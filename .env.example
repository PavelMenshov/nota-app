# =================================
# Nota Platform Environment Configuration
# =================================
# Copy this file to .env in the root directory
# Also copy to packages/database/.env for Prisma CLI

# =================================
# DATABASE
# =================================
# Main database URL for queries and connections
DATABASE_URL="postgresql://nota:nota_dev_password@localhost:5432/nota?schema=public"

# Direct database URL for Prisma migrations and schema management
# For local development, this can be the same as DATABASE_URL
# In production with connection pooling (e.g., PgBouncer), this should be a direct connection
DIRECT_DATABASE_URL="postgresql://nota:nota_dev_password@localhost:5432/nota?schema=public"

# =================================
# REDIS (optional, for caching)
# =================================
REDIS_URL="redis://localhost:6379"

# =================================
# JWT AUTHENTICATION
# =================================
# Generate a secure random string for production
# You can use: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# =================================
# FILE STORAGE (S3-compatible)
# =================================
# For local development with MinIO:
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="nota_minio"
S3_SECRET_KEY="nota_minio_password"
S3_BUCKET="nota-files"
S3_REGION="us-east-1"

# For production with AWS S3:
# S3_ENDPOINT="https://s3.amazonaws.com"
# S3_ACCESS_KEY="your-aws-access-key"
# S3_SECRET_KEY="your-aws-secret-key"
# S3_BUCKET="your-bucket-name"
# S3_REGION="your-aws-region"

# =================================
# AI SERVICES (REQUIRED FOR AI FEATURES)
# =================================
# Choose one provider and set the API key

# Option 1: OpenAI
# Register at: https://platform.openai.com/signup
# Get API key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=""
# OPENAI_MODEL="gpt-4-turbo-preview"

# Option 2: Anthropic Claude
# Register at: https://console.anthropic.com/
# ANTHROPIC_API_KEY=""
# ANTHROPIC_MODEL="claude-3-opus-20240229"

# AI Provider selection (openai or anthropic)
AI_PROVIDER="openai"
AI_DAILY_LIMIT="50"
# Optional: URL for university library/knowledge-base agent (for deeper academic context)
# LIBRARY_AGENT_URL=""

# =================================
# CORS & FRONTEND
# =================================
CORS_ORIGIN="http://localhost:3001"
NEXT_PUBLIC_API_URL="http://localhost:4000"

# =================================
# SERVER
# =================================
PORT=4000
NODE_ENV="development"

# =================================
# OPTIONAL: OAUTH PROVIDERS (SSO)
# =================================
# Google OAuth
# Register at: https://console.cloud.google.com/
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# GitHub OAuth
# Register at: https://github.com/settings/developers
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""

# =================================
# OPTIONAL: EMAIL SERVICE
# =================================
# For sending verification emails, password resets, etc.
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASSWORD=""
# EMAIL_FROM="noreply@nota.app"

# =================================
# OPTIONAL: ANALYTICS
# =================================
# NEXT_PUBLIC_POSTHOG_KEY=""
# NEXT_PUBLIC_POSTHOG_HOST=""
