// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ================================
// AUTH & IDENTITY
// ================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  name          String?
  avatarUrl     String?
  /// JSON: { quickLinks?: { library?: { provider, customUrl?, customLabel? }, classroom?: { provider, customUrl?, customLabel? } } }
  preferences   Json?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  accounts           Account[]
  sessions           Session[]
  workspaceMembers   WorkspaceMember[]
  pagePermissions    PagePermission[]
  comments           Comment[]
  activities         Activity[]
  tasks              Task[]
  taskAssignees      TaskAssignee[]
  calendarEvents     CalendarEvent[]
  aiUsage            AIUsage[]
  exportJobs         ExportJob[]
  pdfAnnotations     PDFAnnotation[]
  flashcardSets      FlashcardSet[]
  lmsIntegrations    LmsIntegration[]
  notifications      Notification[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refreshToken      String? @db.Text
  accessToken       String? @db.Text
  expiresAt         Int?
  tokenType         String?
  scope             String?
  idToken           String? @db.Text
  sessionState      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ================================
// WORKSPACES & PAGES
// ================================

model Workspace {
  id          String   @id @default(cuid())
  name        String
  description String?
  iconUrl     String?
  
  // Share link settings
  shareLink    String?  @unique
  shareLinkEnabled Boolean @default(false)
  shareRole    Role     @default(VIEWER)
  
  /// When set, workspace is in bin; purged after retention days (e.g. 14)
  deletedAt   DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  members          WorkspaceMember[]
  pages            Page[]
  tasks            Task[]
  calendarEvents   CalendarEvent[]
  lmsIntegrationId String?   @unique
  lmsIntegration   LmsIntegration? @relation(fields: [lmsIntegrationId], references: [id], onDelete: SetNull)

  @@map("workspaces")
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  role        Role     @default(VIEWER)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

enum Role {
  OWNER
  EDITOR
  VIEWER
}

model Page {
  id          String   @id @default(cuid())
  workspaceId String
  title       String
  icon        String?
  coverImage  String?
  
  // Tags for search and filtering
  tags        String[] @default([])
  
  // Share link settings
  shareLink    String?  @unique
  shareLinkEnabled Boolean @default(false)
  shareRole    Role     @default(VIEWER)
  
  // Ordering
  order       Int      @default(0)
  parentId    String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  workspace     Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parent        Page?            @relation("PageHierarchy", fields: [parentId], references: [id])
  children      Page[]           @relation("PageHierarchy")
  permissions   PagePermission[]
  doc           Doc?
  canvas        Canvas?
  sources       Source[]
  activities    Activity[]
  tasks         Task[]
  calendarEvents CalendarEvent[]

  @@map("pages")
}

model PagePermission {
  id     String @id @default(cuid())
  pageId String
  userId String
  role   Role   @default(VIEWER)
  
  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pageId, userId])
  @@map("page_permissions")
}

// ================================
// DOC (Document/Notes)
// ================================

model Doc {
  id        String   @id @default(cuid())
  pageId    String   @unique
  content   Json?    // JSON representation of the document (e.g., TipTap, Slate)
  plainText String?  @db.Text // For search indexing
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  page      Page        @relation(fields: [pageId], references: [id], onDelete: Cascade)
  snapshots DocSnapshot[]
  comments  Comment[]

  @@map("docs")
}

model DocSnapshot {
  id        String   @id @default(cuid())
  docId     String
  content   Json
  plainText String?  @db.Text
  version   Int
  
  createdAt DateTime @default(now())
  createdBy String?
  
  doc Doc @relation(fields: [docId], references: [id], onDelete: Cascade)

  @@map("doc_snapshots")
}

// ================================
// CANVAS (Whiteboard)
// ================================

model Canvas {
  id        String   @id @default(cuid())
  pageId    String   @unique
  content   Json?    // JSON representation of canvas elements
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  page      Page          @relation(fields: [pageId], references: [id], onDelete: Cascade)
  snapshots CanvasSnapshot[]
  comments  Comment[]

  @@map("canvases")
}

model CanvasSnapshot {
  id        String   @id @default(cuid())
  canvasId  String
  content   Json
  version   Int
  
  createdAt DateTime @default(now())
  createdBy String?
  
  canvas Canvas @relation(fields: [canvasId], references: [id], onDelete: Cascade)

  @@map("canvas_snapshots")
}

// ================================
// SOURCES (PDF Materials)
// ================================

model Source {
  id          String   @id @default(cuid())
  pageId      String
  fileName    String
  fileUrl     String
  fileSize    Int
  mimeType    String   @default("application/pdf")
  
  // Extracted text for search
  extractedText String? @db.Text
  
  // Metadata
  pageCount   Int?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  page        Page           @relation(fields: [pageId], references: [id], onDelete: Cascade)
  annotations PDFAnnotation[]

  @@map("sources")
}

model PDFAnnotation {
  id          String   @id @default(cuid())
  sourceId    String
  userId      String
  
  // Annotation data
  type        AnnotationType
  content     String?  @db.Text
  color       String?
  pageNumber  Int
  
  // Position data (JSON with coordinates)
  position    Json
  
  // Selected text for highlights
  selectedText String? @db.Text
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  source Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("pdf_annotations")
}

enum AnnotationType {
  HIGHLIGHT
  NOTE
  DRAWING
  TEXT
}

// ================================
// COMMENTS
// ================================

model Comment {
  id        String   @id @default(cuid())
  docId     String?  // Set for doc comments
  canvasId  String?  // Set for canvas comments
  userId    String
  content   String   @db.Text
  
  // For inline comments (position in doc or canvas)
  position  Json?
  
  // Thread support
  parentId  String?
  resolved  Boolean  @default(false)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  doc     Doc?     @relation(fields: [docId], references: [id], onDelete: Cascade)
  canvas  Canvas?  @relation(fields: [canvasId], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent  Comment? @relation("CommentThread", fields: [parentId], references: [id])
  replies Comment[] @relation("CommentThread")

  @@map("comments")
}

// ================================
// ACTIVITY/HISTORY
// ================================

model Activity {
  id        String   @id @default(cuid())
  pageId    String
  userId    String
  action    String   // e.g., "created", "edited", "deleted"
  details   Json?
  
  createdAt DateTime @default(now())
  
  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("activities")
}

// ================================
// TASKS
// ================================

model Task {
  id          String     @id @default(cuid())
  workspaceId String
  pageId      String?
  creatorId   String
  
  title       String
  description String?    @db.Text
  status      TaskStatus @default(TODO)
  priority    Priority   @default(MEDIUM)
  dueDate     DateTime?
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  
  // Relations
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  page        Page?          @relation(fields: [pageId], references: [id], onDelete: SetNull)
  creator     User           @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  assignees   TaskAssignee[]

  @@map("tasks")
}

model TaskAssignee {
  id     String @id @default(cuid())
  taskId String
  userId String
  
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@map("task_assignees")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ================================
// CALENDAR
// ================================

model CalendarEvent {
  id          String   @id @default(cuid())
  workspaceId String
  pageId      String?
  creatorId   String
  
  title       String
  description String?  @db.Text
  startTime   DateTime
  endTime     DateTime
  allDay      Boolean  @default(false)
  location    String?
  color       String?
  /// Zoom, Meet, Teams or Outlook meeting link
  meetingUrl  String?
  
  // Recurrence (optional, simplified)
  recurrence  Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  page        Page?     @relation(fields: [pageId], references: [id], onDelete: SetNull)
  creator     User      @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@map("calendar_events")
}

// ================================
// AI FUNCTIONS
// ================================

model AIUsage {
  id        String   @id @default(cuid())
  userId    String
  type      AIUsageType
  tokens    Int
  
  createdAt DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ai_usage")
}

enum AIUsageType {
  SUMMARY
  FLASHCARDS
  CHAT
  OTHER
}

model FlashcardSet {
  id        String   @id @default(cuid())
  userId    String
  title     String
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards Flashcard[]

  @@map("flashcard_sets")
}

model Flashcard {
  id        String   @id @default(cuid())
  setId     String
  front     String   @db.Text
  back      String   @db.Text
  
  // Spaced repetition data
  interval  Int      @default(0)
  easeFactor Float   @default(2.5)
  dueDate   DateTime @default(now())
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  set FlashcardSet @relation(fields: [setId], references: [id], onDelete: Cascade)

  @@map("flashcards")
}

// ================================
// EXPORT JOBS
// ================================

model ExportJob {
  id        String       @id @default(cuid())
  userId    String
  type      ExportType
  status    JobStatus    @default(PENDING)
  
  // Job config
  config    Json
  
  // Result
  resultUrl String?
  error     String?
  
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("export_jobs")
}

enum ExportType {
  PDF
  DOCX
  MARKDOWN
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ================================
// LMS (Learning Management System)
// ================================

enum LmsProvider {
  BLACKBOARD
  CANVAS
  MOODLE
}

model LmsIntegration {
  id           String       @id @default(cuid())
  userId       String
  provider     LmsProvider
  baseUrl      String       @db.Text
  accessToken  String       @db.Text  // Stored as-is for demo; encrypt in production
  refreshToken String?      @db.Text
  
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  courses       Course[]
  workspaces    Workspace[]
  announcements LmsAnnouncement[]

  @@map("lms_integrations")
}

model LmsAnnouncement {
  id               String   @id @default(cuid())
  lmsIntegrationId String
  courseId         String?
  externalId       String
  title            String
  body             String?  @db.Text
  createdAt        DateTime
  syncedAt         DateTime @default(now())
  
  lmsIntegration LmsIntegration @relation(fields: [lmsIntegrationId], references: [id], onDelete: Cascade)
  course         Course?         @relation(fields: [courseId], references: [id], onDelete: SetNull)
  
  @@unique([lmsIntegrationId, externalId])
  @@map("lms_announcements")
}

model Course {
  id               String    @id @default(cuid())
  lmsIntegrationId String
  externalId       String
  name             String
  code             String?
  term             String?
  syncedAt         DateTime  @default(now())
  
  lmsIntegration LmsIntegration  @relation(fields: [lmsIntegrationId], references: [id], onDelete: Cascade)
  assignments    Assignment[]
  grades         Grade[]
  announcements  LmsAnnouncement[]

  @@unique([lmsIntegrationId, externalId])
  @@map("lms_courses")
}

model Grade {
  id               String    @id @default(cuid())
  courseId         String
  externalColumnId String
  name             String
  score            Float?
  maxScore         Float?
  letterGrade      String?
  feedback         String?   @db.Text
  syncedAt         DateTime  @default(now())
  
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  @@unique([courseId, externalColumnId])
  @@map("lms_grades")
}

model Assignment {
  id        String    @id @default(cuid())
  courseId  String
  externalId String
  name      String
  dueDate   DateTime?
  points    Float?
  
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, externalId])
  @@map("lms_assignments")
}

// ================================
// NOTIFICATIONS
// ================================

enum NotificationType {
  UPCOMING_DEADLINE
  UPCOMING_EVENT
  COLLABORATION_REQUEST
  OTHER
}

model Notification {
  id         String           @id @default(cuid())
  userId     String
  type       NotificationType
  title      String
  body       String?          @db.Text
  read       Boolean          @default(false)
  link       String?          @db.Text
  relatedId  String?
  createdAt  DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}
